BOT_TOKEN=your-telegram-bot-token
BOT_USERNAME=your_bot_username

MAX_FILE_SIZE_MB=50
MAX_BUFFER_SIZE_MB=50
RATE_LIMIT_PER_MIN=10
MAX_RETRY_ATTEMPTS=3
MAX_CONCURRENT_DOWNLOADS=5

ENABLE_INLINE_MODE=false
ENABLE_AUDIO_EXTRACT=false

SUPPORTED_PLATFORMS=tiktok,instagram

# Optional: Path to Instagram cookies (enables Stories download)
# INSTAGRAM_COOKIES_FILE=instagram_cookies.txt

# Optional: Base64-encoded cookies for Railway/deploy (alternative to file)
# Encode locally: base64 -i instagram_cookies.txt | tr -d '\n' | pbcopy
# INSTAGRAM_COOKIES_BASE64=<paste from clipboard>
